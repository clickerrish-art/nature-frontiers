# YouTube Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UC41xXhw22o6Q2I2pTKB2kOg

# Monitored Playlists (comma-separated)
YOUTUBE_PLAYLISTS=PLhErNUuDxs_2F8ayJ_XDrgCbH-CiAqRcd,PLhErNUuDxs_04gGj-HoaSkXNQ1bno89I8,PLhErNUuDxs_0OFY1a8itinxcWutV7oN78,PLhErNUuDxs_3s5P3kfBg1wZdWJY_PmAfC

# Check interval in minutes (for local testing; GitHub Actions uses cron)
CHECK_INTERVAL_MINUTES=30

# Qwen/DashScope Configuration
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus
MAX_TITLE_LENGTH=100

# Twitter/X API Credentials
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_URN
# LINKEDIN_ORGANIZATION_URN=urn:li:organization:YOUR_ORG_URN  # Optional, for company pages

# Platform Toggles (true/false)
ENABLE_TWITTER=true
ENABLE_INSTAGRAM=true
ENABLE_TIKTOK=true
ENABLE_LINKEDIN=true

# LinkedIn Post Mode: 'link' (default, safer) or 'native' (video upload)
LINKEDIN_POST_MODE=link

# Logging
LOG_LEVEL=INFO

# Output directory
OUTPUT_DIR=output

# State file for tracking processed videos
STATE_FILE=processed_videos.txt
